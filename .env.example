# --- Database -------------------------------------------------------------
# Postgres connection string. Local example shown; swap for your provider
# (Supabase, Neon, Railway, RDS, etc.). Neon/Supabase poolers usually want
# ?sslmode=require and sometimes ?pgbouncer=true on the pooled URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lead_crm?schema=public"

# --- Google Gemini --------------------------------------------------------
# Get a key from https://aistudio.google.com/apikey
# Server-side only. Never expose this with the NEXT_PUBLIC_ prefix.
GEMINI_API_KEY="your-gemini-api-key-here"

# --- Auth -----------------------------------------------------------------
# Secret used to sign the session cookie (JWT). Use any long random string
# (32+ characters). Generate one in a password manager, or at
# https://generate-secret.vercel.app/32 . Keep it private; changing it later
# logs you out.
AUTH_SECRET="change-me-to-a-long-random-string"
